# PostgreSQL connection (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://USER@localhost:5432/resume_matcher

DEBUG=false

# Embeddings — free Jina API key from https://jina.ai/embeddings/ (starts with jina_)
JINA_API_KEY=

# AI suggestions — free Groq key from https://console.groq.com (starts with gsk_)
# Leave empty to fall back to a local Ollama server instead.
GROQ_API_KEY=

# Comma-separated list of allowed frontend origins (no JSON brackets)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
